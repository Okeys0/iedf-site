# Copy this file to .env.local and fill in real values before running the app
# against live services. The app runs and builds fine without these — forms
# log to console and content reads from lib/content/ stubs until wired up.

# Site URL — used for resolving absolute Open Graph/social image URLs.
# Update once a custom domain is confirmed (Brief, Open Question 3).
NEXT_PUBLIC_SITE_URL=https://iedf-site.vercel.app

# Sanity (CMS) — see lib/sanity/client.ts
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Postgres (form submissions) — provider TBD, Neon or Supabase (see
# Technical Architecture, Section 11)
DATABASE_URL=

# Resend (transactional/routed email)
RESEND_API_KEY=

# Newsletter ESP — provider TBD, Buttondown or Mailchimp
NEWSLETTER_API_KEY=

# Cloudflare Turnstile (spam protection)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
